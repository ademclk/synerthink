{
  "routes": [
    {
      "route": "/assets/*",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable"
      }
    },
    {
      "route": "/vendor/*",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable"
      }
    },
    {
      "route": "/hero-core.png",
      "headers": {
        "Cache-Control": "public, max-age=604800"
      }
    },
    {
      "route": "/hero-core.avif",
      "headers": {
        "Cache-Control": "public, max-age=604800"
      }
    },
    {
      "route": "/hero-core.webp",
      "headers": {
        "Cache-Control": "public, max-age=604800"
      }
    },
    {
      "route": "/hero-core-320.avif",
      "headers": {
        "Cache-Control": "public, max-age=604800"
      }
    },
    {
      "route": "/hero-core-320.webp",
      "headers": {
        "Cache-Control": "public, max-age=604800"
      }
    },
    {
      "route": "/pixel-hero.svg",
      "headers": {
        "Cache-Control": "public, max-age=604800"
      }
    },
    {
      "route": "/wordmark-synerthink.svg",
      "headers": {
        "Cache-Control": "public, max-age=604800"
      }
    },
    {
      "route": "/favicon.ico",
      "headers": {
        "Cache-Control": "public, max-age=604800"
      }
    },
    {
      "route": "/site.webmanifest",
      "headers": {
        "Cache-Control": "public, max-age=86400"
      }
    },
    {
      "route": "/index.html",
      "redirect": "/"
    },
    {
      "route": "/blog/",
      "redirect": "/blog",
      "statusCode": 301
    },
    {
      "route": "/products/",
      "redirect": "/products",
      "statusCode": 301
    },
    {
      "route": "/_serverFn/*",
      "rewrite": "/api/server"
    },
    {
      "route": "/",
      "rewrite": "/api/server"
    }
  ],
  "platform": {
    "apiRuntime": "node:20"
  },
  "navigationFallback": {
    "rewrite": "/api/server"
  }
}
